#!/usr/bin/env bash
set -euo pipefail

DEV_DIR="${TMUX_MANAGER_DEV_DIR:-$HOME/dev}"
EDITOR_CMD="${EDITOR:-vi}"
GHOSTTY_APP="${TMUX_MANAGER_GHOSTTY_APP:-/Applications/Ghostty.app}"

if [[ -t 1 ]]; then
  BOLD="$(tput bold 2>/dev/null || true)"
  DIM="$(tput dim 2>/dev/null || true)"
  REVERSE="$(tput rev 2>/dev/null || true)"
  GREEN="$(tput setaf 2 2>/dev/null || true)"
  YELLOW="$(tput setaf 3 2>/dev/null || true)"
  RED="$(tput setaf 1 2>/dev/null || true)"
  CYAN="$(tput setaf 6 2>/dev/null || true)"
  RESET="$(tput sgr0 2>/dev/null || true)"
else
  BOLD=""
  DIM=""
  REVERSE=""
  GREEN=""
  YELLOW=""
  RED=""
  CYAN=""
  RESET=""
fi

die() {
  echo "tmuxmanager: $*" >&2
  exit 1
}

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "$1 is required"
}

usage() {
  cat <<'EOF'
TmuxManager

Usage:
  tmuxmanager                 Open the interactive session list
  tmuxmanager list            List discovered tmux scripts
  tmuxmanager sessions        List running tmux sessions
  tmuxmanager start [query]   Start a discovered script
  tmuxmanager stop [query]    Stop the inferred or selected session
  tmuxmanager restart [query] Restart the inferred or selected session
  tmuxmanager attach [query]  Attach to a running session
  tmuxmanager logs [query]    Show captured pane output for a session
  tmuxmanager grep PATTERN    Search captured pane output across sessions
  tmuxmanager edit [query]    Open a discovered script in $EDITOR

Environment:
  TMUX_MANAGER_DEV_DIR        Directory to scan, default: ~/dev
  TMUX_MANAGER_GHOSTTY_APP    Ghostty app path, default: /Applications/Ghostty.app
  TMUX_MANAGER_GHOSTTY        Set to 0 to attach in the current terminal
EOF
}

discover_scripts() {
  [[ -d "$DEV_DIR" ]] || die "dev directory not found: $DEV_DIR"

  find "$DEV_DIR" \
    \( -path '*/.git' -o -path '*/node_modules' -o -path '*/bin' -o -path '*/obj' \) -prune \
    -o -type f -name '*tmux*.sh' -print 2>/dev/null |
    while IFS= read -r file; do
      if [[ "$(basename "$file")" == "tmuxmanager" ]]; then
        continue
      fi

      if [[ -x "$file" ]] || head -n 1 "$file" 2>/dev/null | grep -qE '^#!'; then
        if grep -qE '(^|[^[:alnum:]_])tmux([^[:alnum:]_]|$)' "$file" 2>/dev/null || [[ "$(basename "$file")" == *tmux* ]]; then
          printf '%s\n' "$file"
        fi
      fi
    done |
    sort
}

script_label() {
  local script="$1"
  local project
  project="$(basename "$(dirname "$script")")"
  printf '%s  (%s)' "$project" "${script#$DEV_DIR/}"
}

project_dir_from_script() {
  local script="$1"
  dirname "$script"
}

git_summary() {
  local script="$1"
  local project_dir branch porcelain added removed untracked branch_cell add_cell remove_cell untracked_cell

  project_dir="$(project_dir_from_script "$script")"
  if ! git -C "$project_dir" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    printf '%-32s' ''
    return
  fi

  branch="$(git -C "$project_dir" branch --show-current 2>/dev/null || true)"
  if [[ -z "$branch" ]]; then
    branch="$(git -C "$project_dir" rev-parse --short HEAD 2>/dev/null || true)"
  fi

  porcelain="$(git -C "$project_dir" status --porcelain 2>/dev/null || true)"
  untracked="$(printf '%s\n' "$porcelain" | awk 'substr($0, 1, 2) == "??" { count++ } END { print count + 0 }')"
  read -r added removed < <(
    git -C "$project_dir" diff --numstat HEAD 2>/dev/null |
      awk '
        $1 ~ /^[0-9]+$/ { added += $1 }
        $2 ~ /^[0-9]+$/ { removed += $2 }
        END { print added + 0, removed + 0 }
      '
  )

  printf -v branch_cell '%-15s' "${branch:0:15}"
  printf -v add_cell '+%-5s' "$added"
  printf -v remove_cell -- '-%-5s' "$removed"
  printf -v untracked_cell '?%-3s' "$untracked"

  printf '%s%s%s %s%s%s%s%s%s%s%s%s' \
    "$CYAN" "$branch_cell" "$RESET" \
    "$GREEN" "$add_cell" "$RESET" \
    "$RED" "$remove_cell" "$RESET" \
    "$YELLOW" "$untracked_cell" "$RESET"
}

warning_reason() {
  local session="$1"
  local target output

  while IFS= read -r target; do
    output="$(tmux capture-pane -p -S -80 -t "$target" 2>/dev/null || true)"
    if printf '%s\n' "$output" | grep -Eiq '(^|[^[:alnum:]_])fatal([^[:alnum:]_]|$)'; then
      printf 'fatal in %s' "$target"
      return
    fi
    if printf '%s\n' "$output" | grep -Eiq 'eaddrinuse|address already in use'; then
      printf 'port in use in %s' "$target"
      return
    fi
    if printf '%s\n' "$output" | grep -Eiq '(^|[^[:alnum:]_])unhandled exception([^[:alnum:]_]|$)|(^|[^[:alnum:]_])uncaught exception([^[:alnum:]_]|$)'; then
      printf 'exception in %s' "$target"
      return
    fi
    if printf '%s\n' "$output" | grep -Eiq '(^|[^[:alnum:]_])(command failed|exited with code|killed: 9)([^[:alnum:]_]|$)'; then
      printf 'process failed in %s' "$target"
      return
    fi
  done < <(tmux list-panes -a -F '#S:#I.#P' 2>/dev/null | awk -F: -v s="$session" '$1 == s { print }')
}

session_health() {
  local session="$1"

  if ! is_session_running "$session"; then
    printf 'stopped'
    return
  fi

  if [[ -n "$(warning_reason "$session")" ]]; then
    printf 'warning'
    return
  fi

  printf 'running'
}

status_icon() {
  local health="$1"
  case "$health" in
    running) printf '%s●%s' "$GREEN" "$RESET" ;;
    warning) printf '%s●%s' "$YELLOW" "$RESET" ;;
    *) printf '%s●%s' "$RED" "$RESET" ;;
  esac
}

status_text() {
  local health="$1"
  case "$health" in
    running) printf 'running' ;;
    warning) printf 'warning' ;;
    *) printf 'stopped' ;;
  esac
}

session_from_script() {
  local script="$1"
  local session

  session="$(
    grep -E '^[[:space:]]*(SESSION|SESSION_NAME|TMUX_SESSION|TMUX_SESSION_NAME)=' "$script" 2>/dev/null |
      head -n 1 |
      sed -E 's/^[[:space:]]*[[:alnum:]_]+="\$\{[^:}]+:-([^}]+)\}".*/\1/; s/^[[:space:]]*[[:alnum:]_]+="?([^"]+)"?.*/\1/' || true
  )"

  if [[ -n "$session" && "$session" != *'$'* && "$session" != *'{'* ]]; then
    printf '%s\n' "$session"
    return
  fi

  printf '%s-dev\n' "$(basename "$(dirname "$script")" | tr '[:upper:] _' '[:lower:]-')"
}

tmux_sessions() {
  tmux list-sessions -F '#S' 2>/dev/null || true
}

is_session_running() {
  local session="$1"
  tmux has-session -t "$session" 2>/dev/null
}

pick_from_lines() {
  local prompt="$1"
  local lines="$2"
  local count choice

  [[ -n "$lines" ]] || return 1

  if command -v fzf >/dev/null 2>&1; then
    printf '%s\n' "$lines" | fzf --prompt="$prompt"
    return
  fi

  count="$(printf '%s\n' "$lines" | sed '/^$/d' | wc -l | tr -d ' ')"
  if [[ "$count" == "1" ]]; then
    printf '%s\n' "$lines"
    return
  fi

  printf '%s\n' "$lines" | nl -w 2 -s ') '
  printf '%s ' "$prompt" >&2
  read -r choice
  [[ "$choice" =~ ^[0-9]+$ ]] || return 1
  printf '%s\n' "$lines" | sed -n "${choice}p"
}

select_script() {
  local query="${1:-}"
  local scripts matches selected
  scripts="$(discover_scripts)"
  [[ -n "$scripts" ]] || die "no tmux scripts found under $DEV_DIR"

  if [[ -n "$query" ]]; then
    matches="$(printf '%s\n' "$scripts" | grep -i -- "$query" || true)"
  else
    matches="$scripts"
  fi

  [[ -n "$matches" ]] || die "no tmux script matched: $query"

  selected="$(pick_from_lines "script> " "$matches")" || die "no script selected"
  printf '%s\n' "$selected"
}

select_session() {
  local query="${1:-}"
  local sessions matches selected
  sessions="$(tmux_sessions)"
  [[ -n "$sessions" ]] || die "no tmux sessions are running"

  if [[ -n "$query" ]]; then
    matches="$(printf '%s\n' "$sessions" | grep -i -- "$query" || true)"
  else
    matches="$sessions"
  fi

  [[ -n "$matches" ]] || die "no tmux session matched: $query"

  selected="$(pick_from_lines "session> " "$matches")" || die "no session selected"
  printf '%s\n' "$selected"
}

list_scripts() {
  local script session health status icon detail
  discover_scripts | while IFS= read -r script; do
    session="$(session_from_script "$script")"
    health="$(session_health "$session")"
    status="$(status_text "$health")"
    icon="$(status_icon "$health")"
    detail=""
    [[ "$health" == "warning" ]] && detail="  ($(warning_reason "$session"))"
    printf '%s %-8s %-24s %s%s\n' "$icon" "$status" "$session" "${script#$DEV_DIR/}" "$detail"
  done
}

read_key() {
  local key rest
  IFS= read -rsn1 key
  if [[ "$key" == $'\e' ]]; then
    IFS= read -rsn2 -t 1 rest || true
    key+="$rest"
  fi
  printf '%s' "$key"
}

run_project_picker() {
  local scripts=()
  local base_rows=()
  local git_rows=()
  local warning_rows=()
  local selected=0
  local key count script session health status icon rel_path warning_detail

  while IFS= read -r script; do
    scripts+=("$script")
  done < <(discover_scripts)

  ((${#scripts[@]} > 0)) || die "no tmux scripts found under $DEV_DIR"
  count="${#scripts[@]}"

  for script in "${scripts[@]}"; do
    session="$(session_from_script "$script")"
    health="$(session_health "$session")"
    status="$(status_text "$health")"
    icon="$(status_icon "$health")"
    rel_path="${script#$DEV_DIR/}"
    warning_detail=""
    [[ "$health" == "warning" ]] && warning_detail="  ($(warning_reason "$session"))"
    base_rows+=("$(printf '%s %-8s %-22s' "$icon" "$status" "$session")")
    git_rows+=("$(git_summary "$script")")
    warning_rows+=("$(printf '  %-34s%s' "${rel_path:0:34}" "$warning_detail")")
  done

  while true; do
    clear >&2 2>/dev/null || true
    printf '%s◆ %sTmux%sManager%s  %sproject control%s\n\n' "$CYAN" "$BOLD" "$GREEN" "$CYAN" "$DIM" "$RESET" >&2
    for i in "${!base_rows[@]}"; do
      if (( i == selected )); then
        printf '%s❯ %s %s%s%s\n' "$REVERSE" "${base_rows[$i]}" "${git_rows[$i]}" "${warning_rows[$i]}" "$RESET" >&2
      else
        printf '  %s %s%s\n' "${base_rows[$i]}" "${git_rows[$i]}" "${warning_rows[$i]}" >&2
      fi
    done
    printf '\n%s%s%s\n' "$DIM" "↑/↓ move  Enter start/open  s stop  r reload  g git  Esc quit" "$RESET" >&2

    key="$(read_key)"
    case "$key" in
      $'\e[A'|k)
        if (( selected == 0 )); then
          selected=$((count - 1))
        else
          selected=$((selected - 1))
        fi
        ;;
      $'\e[B'|j)
        selected=$(((selected + 1) % count))
        ;;
      "")
        printf 'enter:%s\n' "$selected"
        return 0
        ;;
      r)
        printf 'restart:%s\n' "$selected"
        return 0
        ;;
      q)
        ;;
      s)
        printf 'stop:%s\n' "$selected"
        return 0
        ;;
      g)
        for i in "${!scripts[@]}"; do
          git_rows[$i]="$(git_summary "${scripts[$i]}")"
        done
        ;;
      $'\e')
        return 1
        ;;
    esac
  done
}

start_script() {
  local script="$1"
  [[ -x "$script" ]] || chmod +x "$script"
  "$script" --no-attach
}

open_command_in_ghostty() {
  local command="$1"
  local restore_clipboard
  if [[ ! -d "$GHOSTTY_APP" ]]; then
    echo "Ghostty app not found: $GHOSTTY_APP"
    return 1
  fi

  if ! pgrep -x ghostty >/dev/null 2>&1; then
    open -na "$GHOSTTY_APP" --args -e /bin/zsh -lc "$command" >/dev/null 2>&1
    return
  fi

  restore_clipboard="$(pbpaste 2>/dev/null || true)"
  osascript - "$command" "$restore_clipboard" <<'APPLESCRIPT'
on run argv
  set commandText to item 1 of argv
  set oldClipboard to item 2 of argv

  tell application "System Events"
    keystroke "t" using command down
    delay 0.15
    set the clipboard to commandText
    keystroke "v" using command down
    key code 36
    delay 0.05
    set the clipboard to oldClipboard
  end tell
end run
APPLESCRIPT
}

open_session_in_ghostty() {
  local session="$1"
  local attach_command

  printf -v attach_command 'tmux attach -t %q' "$session"
  open_command_in_ghostty "$attach_command"
}

open_script_in_ghostty() {
  local script="$1"
  local script_command

  [[ -x "$script" ]] || chmod +x "$script"
  printf -v script_command '%q' "$script"
  open_command_in_ghostty "$script_command"
}

open_session() {
  local session="$1"

  if [[ "${TMUX_MANAGER_GHOSTTY:-1}" != "0" ]]; then
    open_session_in_ghostty "$session"
    return
  fi

  tmux attach -t "$session"
}

start_script_and_open() {
  local script="$1"
  local session
  session="$(session_from_script "$script")"
  if is_session_running "$session"; then
    open_session "$session"
    return
  fi

  if [[ "${TMUX_MANAGER_GHOSTTY:-1}" != "0" ]]; then
    open_script_in_ghostty "$script"
    return
  fi

  start_script "$script"
  open_session "$session"
}

stop_session() {
  local session="$1"
  if is_session_running "$session"; then
    tmux kill-session -t "$session"
    echo "Stopped $session"
  else
    echo "$session is not running"
  fi
}

restart_script() {
  local script="$1"
  local session
  session="$(session_from_script "$script")"
  stop_session "$session"
  start_script "$script"
}

capture_session() {
  local session="$1"
  local target
  tmux list-panes -a -F '#S:#I.#P' 2>/dev/null |
    awk -F: -v s="$session" '$1 == s { print }' |
    while IFS= read -r target; do
      printf '\n===== %s =====\n' "$target"
      tmux capture-pane -p -S - -t "$target" 2>/dev/null || true
    done
}

grep_sessions() {
  local pattern="$1"
  local session target
  [[ -n "$pattern" ]] || die "grep requires a pattern"

  tmux list-panes -a -F '#S:#I.#P' 2>/dev/null |
    while IFS=: read -r session target; do
      tmux capture-pane -p -S - -t "$session:$target" 2>/dev/null |
        grep -in -- "$pattern" |
        sed "s|^|$session:$target:|"
    done
}

grep_session() {
  local session="$1"
  local pattern="$2"
  local target
  [[ -n "$pattern" ]] || die "grep requires a pattern"

  if ! is_session_running "$session"; then
    echo "$session is not running"
    return 1
  fi

  tmux list-panes -a -F '#S:#I.#P' 2>/dev/null |
    awk -F: -v s="$session" '$1 == s { print }' |
    while IFS= read -r target; do
      tmux capture-pane -p -S - -t "$target" 2>/dev/null |
        grep -in -- "$pattern" |
        sed "s|^|$target:|"
    done
}

interactive() {
  need_cmd tmux

  while true; do
    local selection action index script session

    selection="$(run_project_picker)" || exit 0
    action="${selection%%:*}"
    index="${selection#*:}"
    script="$(discover_scripts | sed -n "$((index + 1))p")"
    [[ -n "$script" ]] || continue

    session="$(session_from_script "$script")"

    case "$action" in
      enter)
        if is_session_running "$session"; then
          open_session_in_ghostty "$session" || sleep 1
        else
          open_script_in_ghostty "$script" || sleep 1
        fi
        ;;
      stop)
        stop_session "$session"
        ;;
      restart)
        stop_session "$session"
        open_script_in_ghostty "$script" || sleep 1
        ;;
    esac
  done
}

main() {
  local command="${1:-}"
  local script session

  case "$command" in
    "" ) interactive ;;
    -h|--help|help) usage ;;
    list) list_scripts ;;
    sessions) tmux_sessions ;;
    start)
      need_cmd tmux
      script="$(select_script "${2:-}")"
      start_script_and_open "$script"
      ;;
    stop)
      need_cmd tmux
      if [[ -n "${2:-}" ]]; then
        script="$(select_script "$2" 2>/dev/null || true)"
        if [[ -n "$script" ]]; then
          session="$(session_from_script "$script")"
        else
          session="$(select_session "$2")"
        fi
      else
        session="$(select_session)"
      fi
      stop_session "$session"
      ;;
    restart)
      need_cmd tmux
      script="$(select_script "${2:-}")"
      restart_script "$script"
      open_session "$(session_from_script "$script")"
      ;;
    attach)
      need_cmd tmux
      open_session "$(select_session "${2:-}")"
      ;;
    logs)
      need_cmd tmux
      capture_session "$(select_session "${2:-}")"
      ;;
    grep)
      need_cmd tmux
      if [[ -n "${3:-}" ]]; then
        script="$(select_script "$2" 2>/dev/null || true)"
        if [[ -n "$script" ]]; then
          session="$(session_from_script "$script")"
        else
          session="$(select_session "$2")"
        fi
        grep_session "$session" "$3"
      else
        grep_sessions "${2:-}"
      fi
      ;;
    edit)
      "$EDITOR_CMD" "$(select_script "${2:-}")"
      ;;
    *)
      usage
      exit 1
      ;;
  esac
}

main "$@"
