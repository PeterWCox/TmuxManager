#!/usr/bin/env bash
set -euo pipefail

DEV_DIR="${TMUX_MANAGER_DEV_DIR:-$HOME/dev}"
EDITOR_CMD="${EDITOR:-vi}"

if [[ -t 1 ]]; then
  BOLD="$(tput bold 2>/dev/null || true)"
  DIM="$(tput dim 2>/dev/null || true)"
  REVERSE="$(tput rev 2>/dev/null || true)"
  GREEN="$(tput setaf 2 2>/dev/null || true)"
  RED="$(tput setaf 1 2>/dev/null || true)"
  CYAN="$(tput setaf 6 2>/dev/null || true)"
  RESET="$(tput sgr0 2>/dev/null || true)"
else
  BOLD=""
  DIM=""
  REVERSE=""
  GREEN=""
  RED=""
  CYAN=""
  RESET=""
fi

die() {
  echo "tmuxmanager: $*" >&2
  exit 1
}

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "$1 is required"
}

usage() {
  cat <<'EOF'
TmuxManager

Usage:
  tmuxmanager                 Open the interactive session list
  tmuxmanager list            List discovered tmux scripts
  tmuxmanager sessions        List running tmux sessions
  tmuxmanager start [query]   Start a discovered script
  tmuxmanager stop [query]    Stop the inferred or selected session
  tmuxmanager restart [query] Restart the inferred or selected session
  tmuxmanager attach [query]  Attach to a running session
  tmuxmanager logs [query]    Show captured pane output for a session
  tmuxmanager grep PATTERN    Search captured pane output across sessions
  tmuxmanager edit [query]    Open a discovered script in $EDITOR

Environment:
  TMUX_MANAGER_DEV_DIR        Directory to scan, default: ~/dev
EOF
}

discover_scripts() {
  [[ -d "$DEV_DIR" ]] || die "dev directory not found: $DEV_DIR"

  find "$DEV_DIR" \
    \( -path '*/.git' -o -path '*/node_modules' -o -path '*/bin' -o -path '*/obj' \) -prune \
    -o -type f -name '*tmux*.sh' -print 2>/dev/null |
    while IFS= read -r file; do
      if [[ "$(basename "$file")" == "tmuxmanager" ]]; then
        continue
      fi

      if [[ -x "$file" ]] || head -n 1 "$file" 2>/dev/null | grep -qE '^#!'; then
        if grep -qE '(^|[^[:alnum:]_])tmux([^[:alnum:]_]|$)' "$file" 2>/dev/null || [[ "$(basename "$file")" == *tmux* ]]; then
          printf '%s\n' "$file"
        fi
      fi
    done |
    sort
}

script_label() {
  local script="$1"
  local project
  project="$(basename "$(dirname "$script")")"
  printf '%s  (%s)' "$project" "${script#$DEV_DIR/}"
}

status_icon() {
  local session="$1"
  if is_session_running "$session"; then
    printf '%s●%s' "$GREEN" "$RESET"
  else
    printf '%s●%s' "$RED" "$RESET"
  fi
}

status_text() {
  local session="$1"
  if is_session_running "$session"; then
    printf 'running'
  else
    printf 'stopped'
  fi
}

session_from_script() {
  local script="$1"
  local session

  session="$(
    grep -E '^[[:space:]]*SESSION=' "$script" 2>/dev/null |
      head -n 1 |
      sed -E 's/^[[:space:]]*SESSION="\$\{[^:}]+:-([^}]+)\}".*/\1/; s/^[[:space:]]*SESSION="?([^"]+)"?.*/\1/' || true
  )"

  if [[ -n "$session" && "$session" != *'$'* && "$session" != *'{'* ]]; then
    printf '%s\n' "$session"
    return
  fi

  printf '%s-dev\n' "$(basename "$(dirname "$script")" | tr '[:upper:] _' '[:lower:]-')"
}

tmux_sessions() {
  tmux list-sessions -F '#S' 2>/dev/null || true
}

is_session_running() {
  local session="$1"
  tmux has-session -t "$session" 2>/dev/null
}

pick_from_lines() {
  local prompt="$1"
  local lines="$2"
  local count choice

  [[ -n "$lines" ]] || return 1

  if command -v fzf >/dev/null 2>&1; then
    printf '%s\n' "$lines" | fzf --prompt="$prompt"
    return
  fi

  count="$(printf '%s\n' "$lines" | sed '/^$/d' | wc -l | tr -d ' ')"
  if [[ "$count" == "1" ]]; then
    printf '%s\n' "$lines"
    return
  fi

  printf '%s\n' "$lines" | nl -w 2 -s ') '
  printf '%s ' "$prompt" >&2
  read -r choice
  [[ "$choice" =~ ^[0-9]+$ ]] || return 1
  printf '%s\n' "$lines" | sed -n "${choice}p"
}

select_script() {
  local query="${1:-}"
  local scripts matches selected
  scripts="$(discover_scripts)"
  [[ -n "$scripts" ]] || die "no tmux scripts found under $DEV_DIR"

  if [[ -n "$query" ]]; then
    matches="$(printf '%s\n' "$scripts" | grep -i -- "$query" || true)"
  else
    matches="$scripts"
  fi

  [[ -n "$matches" ]] || die "no tmux script matched: $query"

  selected="$(pick_from_lines "script> " "$matches")" || die "no script selected"
  printf '%s\n' "$selected"
}

select_session() {
  local query="${1:-}"
  local sessions matches selected
  sessions="$(tmux_sessions)"
  [[ -n "$sessions" ]] || die "no tmux sessions are running"

  if [[ -n "$query" ]]; then
    matches="$(printf '%s\n' "$sessions" | grep -i -- "$query" || true)"
  else
    matches="$sessions"
  fi

  [[ -n "$matches" ]] || die "no tmux session matched: $query"

  selected="$(pick_from_lines "session> " "$matches")" || die "no session selected"
  printf '%s\n' "$selected"
}

list_scripts() {
  local script session status icon
  discover_scripts | while IFS= read -r script; do
    session="$(session_from_script "$script")"
    status="$(status_text "$session")"
    icon="$(status_icon "$session")"
    printf '%s %-8s %-24s %s\n' "$icon" "$status" "$session" "${script#$DEV_DIR/}"
  done
}

list_picker_rows() {
  local index=1
  local script session status icon
  discover_scripts | while IFS= read -r script; do
    session="$(session_from_script "$script")"
    status="$(status_text "$session")"
    icon="$(status_icon "$session")"
    printf '%2d) %s %-8s %-24s %s\n' "$index" "$icon" "$status" "$session" "${script#$DEV_DIR/}"
    index=$((index + 1))
  done
}

script_by_index() {
  local index="$1"
  discover_scripts | sed -n "${index}p"
}

read_key() {
  local key rest
  IFS= read -rsn1 key
  if [[ "$key" == $'\e' ]]; then
    IFS= read -rsn2 -t 1 rest || true
    key+="$rest"
  fi
  printf '%s' "$key"
}

pick_index() {
  local title="$1"
  local footer="$2"
  shift 2
  local rows=("$@")
  local selected=0
  local key count

  count="${#rows[@]}"
  (( count > 0 )) || return 1

  while true; do
    clear >&2 2>/dev/null || true
    printf '%s%s%s\n\n' "$BOLD" "$title" "$RESET" >&2
    for i in "${!rows[@]}"; do
      if (( i == selected )); then
        printf '%s❯ %s%s\n' "$REVERSE" "${rows[$i]}" "$RESET" >&2
      else
        printf '  %s\n' "${rows[$i]}" >&2
      fi
    done
    printf '\n%s%s%s\n' "$DIM" "$footer" "$RESET" >&2

    key="$(read_key)"
    case "$key" in
      $'\e[A'|k)
        if (( selected == 0 )); then
          selected=$((count - 1))
        else
          selected=$((selected - 1))
        fi
        ;;
      $'\e[B'|j)
        selected=$(((selected + 1) % count))
        ;;
      "")
        printf '%s\n' "$selected"
        return 0
        ;;
      /)
        printf '__grep_all__\n'
        return 0
        ;;
      r)
        printf '__refresh__\n'
        return 0
        ;;
      q|$'\e')
        return 1
        ;;
    esac
  done
}

pick_session_script() {
  local scripts=()
  local rows=()
  local script session status icon selected

  while IFS= read -r script; do
    scripts+=("$script")
  done < <(discover_scripts)

  ((${#scripts[@]} > 0)) || die "no tmux scripts found under $DEV_DIR"

  for script in "${scripts[@]}"; do
    session="$(session_from_script "$script")"
    status="$(status_text "$session")"
    icon="$(status_icon "$session")"
    rows+=("$(printf '%s %-8s %-24s %s' "$icon" "$status" "$session" "${script#$DEV_DIR/}")")
  done

  selected="$(pick_index "TmuxManager" "↑/↓ move  Enter select  / grep all  r refresh  q quit" "${rows[@]}")" || return 1
  if [[ "$selected" == "__grep_all__" || "$selected" == "__refresh__" ]]; then
    printf '%s\n' "$selected"
    return 0
  fi
  printf '%s\n' "${scripts[$selected]}"
}

pick_action() {
  local session="$1"
  local actions=()
  local rows=()
  local selected action

  actions=("grep" "logs" "attach")
  if is_session_running "$session"; then
    actions+=("stop" "restart")
  else
    actions+=("start")
  fi
  actions+=("back")

  for action in "${actions[@]}"; do
    case "$action" in
      grep) rows+=("Grep this session") ;;
      logs) rows+=("Show logs") ;;
      attach) rows+=("Attach") ;;
      stop) rows+=("${RED}Stop${RESET}") ;;
      restart) rows+=("Restart") ;;
      start) rows+=("${GREEN}Start${RESET}") ;;
      back) rows+=("Back") ;;
    esac
  done

  selected="$(pick_index "$session" "↑/↓ move  Enter select  q back" "${rows[@]}")" || {
    printf 'back\n'
    return 0
  }
  if [[ "$selected" == "__grep_all__" || "$selected" == "__refresh__" ]]; then
    printf 'back\n'
    return 0
  fi
  printf '%s\n' "${actions[$selected]}"
}

start_script() {
  local script="$1"
  [[ -x "$script" ]] || chmod +x "$script"
  "$script" --no-attach
}

stop_session() {
  local session="$1"
  if is_session_running "$session"; then
    tmux kill-session -t "$session"
    echo "Stopped $session"
  else
    echo "$session is not running"
  fi
}

restart_script() {
  local script="$1"
  local session
  session="$(session_from_script "$script")"
  stop_session "$session"
  start_script "$script"
}

capture_session() {
  local session="$1"
  local target
  tmux list-panes -a -F '#S:#I.#P' 2>/dev/null |
    awk -F: -v s="$session" '$1 == s { print }' |
    while IFS= read -r target; do
      printf '\n===== %s =====\n' "$target"
      tmux capture-pane -p -S - -t "$target" 2>/dev/null || true
    done
}

grep_sessions() {
  local pattern="$1"
  local session target
  [[ -n "$pattern" ]] || die "grep requires a pattern"

  tmux list-panes -a -F '#S:#I.#P' 2>/dev/null |
    while IFS=: read -r session target; do
      tmux capture-pane -p -S - -t "$session:$target" 2>/dev/null |
        grep -in -- "$pattern" |
        sed "s|^|$session:$target:|"
    done
}

grep_session() {
  local session="$1"
  local pattern="$2"
  local target
  [[ -n "$pattern" ]] || die "grep requires a pattern"

  if ! is_session_running "$session"; then
    echo "$session is not running"
    return 1
  fi

  tmux list-panes -a -F '#S:#I.#P' 2>/dev/null |
    awk -F: -v s="$session" '$1 == s { print }' |
    while IFS= read -r target; do
      tmux capture-pane -p -S - -t "$target" 2>/dev/null |
        grep -in -- "$pattern" |
        sed "s|^|$target:|"
    done
}

interactive() {
  need_cmd tmux

  while true; do
    local script session action pattern key

    script="$(pick_session_script)" || exit 0
    if [[ "$script" == "__refresh__" ]]; then
      continue
    fi

    if [[ "$script" == "__grep_all__" ]]; then
      clear 2>/dev/null || true
      printf '%sGrep all sessions%s\n\n' "$BOLD" "$RESET"
      printf 'pattern> '
      read -r pattern
      grep_sessions "$pattern" || true
      printf '\npress enter to continue> '
      read -r _
      continue
    fi

    session="$(session_from_script "$script")"
    action="$(pick_action "$session")"

    case "$action" in
      grep)
        clear 2>/dev/null || true
        printf '%sGrep %s%s\n\n' "$BOLD" "$session" "$RESET"
        printf 'pattern> '
        read -r pattern
        grep_session "$session" "$pattern" || true
        printf '\npress enter to continue> '
        read -r _
        ;;
      logs)
        clear 2>/dev/null || true
        capture_session "$session"
        printf '\npress enter to continue> '
        read -r _
        ;;
      attach)
        tmux attach -t "$session"
        ;;
      stop)
        clear 2>/dev/null || true
        stop_session "$session"
        printf '\npress enter to continue> '
        read -r _
        ;;
      restart)
        clear 2>/dev/null || true
        restart_script "$script"
        printf '\npress enter to continue> '
        read -r _
        ;;
      start)
        clear 2>/dev/null || true
        start_script "$script"
        printf '\npress enter to continue> '
        read -r _
        ;;
      back) ;;
    esac
  done
}

main() {
  local command="${1:-}"
  local script session

  case "$command" in
    "" ) interactive ;;
    -h|--help|help) usage ;;
    list) list_scripts ;;
    sessions) tmux_sessions ;;
    start)
      need_cmd tmux
      script="$(select_script "${2:-}")"
      start_script "$script"
      ;;
    stop)
      need_cmd tmux
      if [[ -n "${2:-}" ]]; then
        script="$(select_script "$2" 2>/dev/null || true)"
        if [[ -n "$script" ]]; then
          session="$(session_from_script "$script")"
        else
          session="$(select_session "$2")"
        fi
      else
        session="$(select_session)"
      fi
      stop_session "$session"
      ;;
    restart)
      need_cmd tmux
      script="$(select_script "${2:-}")"
      restart_script "$script"
      ;;
    attach)
      need_cmd tmux
      tmux attach -t "$(select_session "${2:-}")"
      ;;
    logs)
      need_cmd tmux
      capture_session "$(select_session "${2:-}")"
      ;;
    grep)
      need_cmd tmux
      if [[ -n "${3:-}" ]]; then
        script="$(select_script "$2" 2>/dev/null || true)"
        if [[ -n "$script" ]]; then
          session="$(session_from_script "$script")"
        else
          session="$(select_session "$2")"
        fi
        grep_session "$session" "$3"
      else
        grep_sessions "${2:-}"
      fi
      ;;
    edit)
      "$EDITOR_CMD" "$(select_script "${2:-}")"
      ;;
    *)
      usage
      exit 1
      ;;
  esac
}

main "$@"
